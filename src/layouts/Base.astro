---
interface Props {
  title: string;
  description?: string;
}
const { title, description = "Devender Gollapally — engineer. Investment platforms, tokenized securities, and production AI in regulated finance. Writing here since 2003." } = Astro.props;
import '../styles/site.css';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="alternate" type="application/rss+xml" title="Devender's Musings" href="/rss.xml" />
  <link rel="sitemap" href="/sitemap-index.xml" />

  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Devender's Musings" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={Astro.url} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght,SOFT,WONK@9..144,300..700,0..100,0..1&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body>
  <header class="site">
    <div class="wrap">
      <a class="brand" href="/">devender<span class="dot">.</span>me</a>
      <nav>
        <a href="/">Writing</a>
        <a href="/about/">About</a>
        <a href="https://mcpwright.com">mcpwright</a>
        <a href="https://github.com/devender">GitHub</a>
      </nav>
    </div>
  </header>

  <main class="wrap">
    <slot />
  </main>

  <footer class="site">
    <div class="wrap">
      Devender Gollapally · writing here since 2003 ·
      <a href="https://mcpwright.com">mcpwright</a> ·
      <a href="https://github.com/devender">GitHub</a> ·
      <a href="/rss.xml">RSS</a>
    </div>
  </footer>
</body>
</html>

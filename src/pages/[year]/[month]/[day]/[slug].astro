---
import Base from '../../../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => {
    const d = post.data.date;
    return {
      params: {
        year: String(d.getUTCFullYear()),
        month: String(d.getUTCMonth() + 1).padStart(2, '0'),
        day: String(d.getUTCDate()).padStart(2, '0'),
        slug: post.data.slug,
      },
      props: { post },
    };
  });
}

const { post } = Astro.props;
const { Content } = await render(post);
const d = post.data.date;
const dateStr = d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' });
---
<Base title={`${post.data.title} — Devender's Musings`}>
  <article class="post">
    <div class="hero" style="padding-bottom: 0;">
      <h1 class="post-title">{post.data.title}</h1>
      <p class="post-meta">
        {dateStr}{post.data.categories.length > 0 && ` · ${post.data.categories.join(', ')}`}
      </p>
    </div>
    <div class="content">
      <Content />
    </div>
  </article>

  <section class="comments">
    <h2>Comments</h2>
    <p class="muted">Sign in with GitHub to comment. Or just say hi
      <a href="https://github.com/devender">on GitHub</a>.</p>
    <script src="https://giscus.app/client.js"
      data-repo="devender/devender.me"
      data-repo-id="R_kgDOSwdbJQ"
      data-category="Announcements"
      data-category-id="DIC_kwDOSwdbJc4C-d0y"
      data-mapping="pathname"
      data-strict="1"
      data-reactions-enabled="1"
      data-emit-metadata="0"
      data-input-position="top"
      data-theme="dark"
      data-lang="en"
      data-loading="lazy"
      crossorigin="anonymous"
      async>
    </script>
  </section>
</Base>
